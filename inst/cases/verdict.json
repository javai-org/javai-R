{
  "suite": "verdict",
  "description": "Verdict evaluation — pass/fail determination with z-test statistics",
  "method": "One-sided z-test: z = (p_hat - threshold) / SE; SE = sqrt(threshold * (1 - threshold) / n)",
  "tolerance": 1e-10,
  "cases": [
    {
      "name": "clear_pass_48_of_50_threshold_90",
      "inputs": {
        "successes": 48,
        "trials": 50,
        "threshold": 0.9,
        "confidence": 0.95
      },
      "expected": {
        "passed": true,
        "observed_rate": 0.96,
        "test_statistic": 1.4142,
        "p_value": 0.9214,
        "false_positive_probability": 0
      }
    },
    {
      "name": "clear_fail_40_of_50_threshold_90",
      "inputs": {
        "successes": 40,
        "trials": 50,
        "threshold": 0.9,
        "confidence": 0.95
      },
      "expected": {
        "passed": false,
        "observed_rate": 0.8,
        "test_statistic": -2.357,
        "p_value": 0.0092,
        "false_positive_probability": 0.05
      }
    },
    {
      "name": "borderline_pass_45_of_50_threshold_90",
      "inputs": {
        "successes": 45,
        "trials": 50,
        "threshold": 0.9,
        "confidence": 0.95
      },
      "expected": {
        "passed": true,
        "observed_rate": 0.9,
        "test_statistic": 0,
        "p_value": 0.5,
        "false_positive_probability": 0
      }
    },
    {
      "name": "perfect_score_50_of_50_threshold_95",
      "inputs": {
        "successes": 50,
        "trials": 50,
        "threshold": 0.95,
        "confidence": 0.95
      },
      "expected": {
        "passed": true,
        "observed_rate": 1,
        "test_statistic": 1.6222,
        "p_value": 0.9476,
        "false_positive_probability": 0
      }
    },
    {
      "name": "zero_successes_0_of_50_threshold_90",
      "inputs": {
        "successes": 0,
        "trials": 50,
        "threshold": 0.9,
        "confidence": 0.95
      },
      "expected": {
        "passed": false,
        "observed_rate": 0,
        "test_statistic": -21.2132,
        "p_value": 3.6065e-100,
        "false_positive_probability": 0.05
      }
    },
    {
      "name": "large_sample_pass_920_of_1000_threshold_90",
      "inputs": {
        "successes": 920,
        "trials": 1000,
        "threshold": 0.9,
        "confidence": 0.95
      },
      "expected": {
        "passed": true,
        "observed_rate": 0.92,
        "test_statistic": 2.1082,
        "p_value": 0.9825,
        "false_positive_probability": 0
      }
    }
  ]
}
