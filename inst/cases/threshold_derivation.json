{
  "suite": "threshold_derivation",
  "description": "Threshold derivation via sample-size-first and threshold-first approaches",
  "method": "Wilson lower bound (sample-size-first); binary search for implied confidence (threshold-first)",
  "tolerance": 1e-06,
  "cases": [
    {
      "name": "ssf_95_of_100_test50_95pct",
      "approach": "sample_size_first",
      "inputs": {
        "baseline_successes": 95,
        "baseline_trials": 100,
        "test_samples": 50,
        "confidence": 0.95
      },
      "expected": {
        "threshold": 0.9008
      }
    },
    {
      "name": "ssf_950_of_1000_test100_95pct",
      "approach": "sample_size_first",
      "inputs": {
        "baseline_successes": 950,
        "baseline_trials": 1000,
        "test_samples": 100,
        "confidence": 0.95
      },
      "expected": {
        "threshold": 0.9374
      }
    },
    {
      "name": "ssf_perfect_baseline_test50_95pct",
      "approach": "sample_size_first",
      "inputs": {
        "baseline_successes": 100,
        "baseline_trials": 100,
        "test_samples": 50,
        "confidence": 0.95
      },
      "expected": {
        "threshold": 0.9737
      }
    },
    {
      "name": "ssf_95_of_100_test50_99pct",
      "approach": "sample_size_first",
      "inputs": {
        "baseline_successes": 95,
        "baseline_trials": 100,
        "test_samples": 50,
        "confidence": 0.99
      },
      "expected": {
        "threshold": 0.8724
      }
    },
    {
      "name": "tf_baseline_95pct_threshold_90",
      "approach": "threshold_first",
      "inputs": {
        "baseline_successes": 95,
        "baseline_trials": 100,
        "threshold": 0.9
      },
      "expected": {
        "implied_confidence": 0.9522,
        "is_sound": true
      }
    },
    {
      "name": "tf_baseline_95pct_threshold_85",
      "approach": "threshold_first",
      "inputs": {
        "baseline_successes": 95,
        "baseline_trials": 100,
        "threshold": 0.85
      },
      "expected": {
        "implied_confidence": 0.9974,
        "is_sound": true
      }
    },
    {
      "name": "tf_baseline_95pct_threshold_94",
      "approach": "threshold_first",
      "inputs": {
        "baseline_successes": 95,
        "baseline_trials": 100,
        "threshold": 0.94
      },
      "expected": {
        "implied_confidence": 0.6632,
        "is_sound": false
      }
    }
  ]
}
