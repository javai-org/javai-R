    {
      "name": "perfect_baseline_moderate_n",
      "description": "A baseline at p_hat_c = 1 over a moderate n_c. Anchors the §4 perfect-baseline two-step under the per-criterion shape: a downstream threshold derivation must compress the observed 1.0 to a Wilson lower bound on the baseline itself before using it as the effective baseline rate.",
      "inputs": {
        "baseline": {
          "factor_record": {
            "service": "schema-validator@1.0",
            "model": "deterministic-validator@1",
            "temperature": 0,
            "system_prompt": "schema-prompt@1"
          },
          "covariate_profile": {
            "day_of_week": "WEEKDAY",
            "time_of_day": "08:00-12:00",
            "region": "EU",
            "serving_stack": "standard"
          },
          "expiration_window": "2026-11-12",
          "structural_reference": "schema-validator@1",
          "criteria": [
            {
              "criterion_id": "c_schema_valid",
              "mode": "inferential",
              "procedure": "REGRESSION",
              "denominator_policy": "MARGINAL_COUNT_UNEVALUABLE_AS_FAIL",
              "observation": {
                "n_attempted": 2000,
                "n_evaluable": 2000,
                "r_obs": 1,
                "n_c": 2000,
                "K_c": 2000,
                "p_hat_c": 1
              }
            }
          ]
        }
      },
      "expected": []
    },
    {
