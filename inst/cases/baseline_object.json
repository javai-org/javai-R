{
  "suite": "baseline_object",
  "description": "Reference baseline objects per companion §1.5 + §1.4.5a. Cases are schema fixtures rather than computation fixtures: each case is a canonical baseline at a stated point in the index space with no expected output (the case itself is the example). Used by downstream frameworks to exercise parser conformance and the structural checks (covariate match, structural-reference match, policy match) that §§1.5.2 and 1.4.5a require.",
  "method": "Object construction. No statistical computation involved; each baseline records the four indices and a list of per-criterion observation blocks under the locked §1.4.5a two-policy enum.",
  "tolerance": 0,
  "cases": [
    {
      "name": "consult_advice_eu_weekday",
      "description": "The consult-advice contract baseline at the EU / weekday / morning point in the index space. Three criteria mix REGRESSION + observational + COMPLIANCE; mixed denominator policies; r_obs = 1.0 throughout.",
      "inputs": {
        "baseline": {
          "factor_record": {
            "service": "consult-advice-service@3.1",
            "model": "claude-sonnet-4-5-20250929",
            "temperature": 0,
            "system_prompt": "consult-advice-prompt@5"
          },
          "covariate_profile": {
            "day_of_week": "WEEKDAY",
            "time_of_day": "08:00-12:00",
            "region": "EU",
            "serving_stack": "standard"
          },
          "expiration_window": "2026-08-13",
          "structural_reference": "consult-advice@5",
          "criteria": [
            {
              "criterion_id": "c_well_formed",
              "mode": "inferential",
              "procedure": "REGRESSION",
              "denominator_policy": "MARGINAL_COUNT_UNEVALUABLE_AS_FAIL",
              "observation": {
                "n_attempted": 1000,
                "n_evaluable": 1000,
                "r_obs": 1,
                "n_c": 1000,
                "K_c": 951,
                "p_hat_c": 0.951
              }
            },
            {
              "criterion_id": "c_no_self_harm",
              "mode": "observational",
              "procedure": null,
              "denominator_policy": "CONDITIONAL_ON_EVALUABLE",
              "observation": {
                "n_attempted": 200,
                "n_evaluable": 200,
                "r_obs": 1,
                "n_c": 200,
                "K_c": 200,
                "p_hat_c": null
              }
            },
            {
              "criterion_id": "c_layperson_readable",
              "mode": "inferential",
              "procedure": "COMPLIANCE",
              "denominator_policy": "CONDITIONAL_ON_EVALUABLE",
              "observation": {
                "n_attempted": 800,
                "n_evaluable": 800,
                "r_obs": 1,
                "n_c": 800,
                "K_c": 788,
                "p_hat_c": 0.985
              }
            }
          ]
        }
      },
      "expected": []
    },
    {
      "name": "guardrail_sentinel_observational_only",
      "description": "A guardrail-validation baseline carrying a single observational criterion at sentinel scale (n_attempted = 10^7) under the MARGINAL_COUNT_UNEVALUABLE_AS_FAIL policy. The accumulation story of §1.5.5: per-run zero-failure observations pooled to a scale that supports a regulator-grade claim.",
      "inputs": {
        "baseline": {
          "factor_record": {
            "service": "moderation-guardrail@2.0",
            "model": "claude-haiku-4-5-20251001",
            "temperature": 0,
            "system_prompt": "moderation-guard-prompt@7"
          },
          "covariate_profile": {
            "day_of_week": "WEEKDAY",
            "time_of_day": "08:00-12:00",
            "region": "EU",
            "serving_stack": "standard"
          },
          "expiration_window": "2026-11-12",
          "structural_reference": "moderation-guardrail@1",
          "criteria": [
            {
              "criterion_id": "c_no_self_harm_sentinel",
              "mode": "observational",
              "procedure": null,
              "denominator_policy": "MARGINAL_COUNT_UNEVALUABLE_AS_FAIL",
              "observation": {
                "n_attempted": 10000000,
                "n_evaluable": 10000000,
                "r_obs": 1,
                "n_c": 10000000,
                "K_c": 10000000,
                "p_hat_c": null
              }
            }
          ]
        }
      },
      "expected": []
    },
    {
